# Dependencies
node_modules/

# Build output
dist/
build/

# Environment files
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Uploads (可选，生产环境建议保留)
# server/uploads/*
# !server/uploads/.gitkeep

# 持久化数据目录（部署时自动创建，不需要版本控制）
persistent-data/

# 备份文件
backups/

# ====== 数据库文件（重要：防止覆盖生产数据）======
# SQLite 数据库文件
server/data/*.db
server/data/*.db-wal
server/data/*.db-shm

# 整个数据目录（可选，更严格的保护）
# server/data/

# ====== 上传文件（可选）======
# 如果不想同步用户上传的图片，取消下面的注释
# server/uploads/
